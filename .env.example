# ============================================================
# Backend (apps/api/.env)
# ============================================================

# Database
DATABASE_URL=postgresql://basedcollective:basedcollective@localhost:5432/basedcollective

# Auth
JWT_SECRET=change-me-to-a-random-string
JWT_EXPIRY=7d

# Seed Admin Account (used by `npm run db:seed`)
ADMIN_EMAIL=admin@basedcollective.com
ADMIN_PASSWORD=change-me
ADMIN_DISPLAY_NAME=Admin

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Worldcoin
WORLDCOIN_APP_ID=
WORLDCOIN_ACTION=verify-human
WORLDCOIN_MOCK=true

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=basedcollective-media
R2_PUBLIC_URL=

# Resend (email)
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@basedcollective.com

# Frontend URL (for CORS, email links)
FRONTEND_URL=http://localhost:3000

# ============================================================
# Frontend (apps/web/.env)
# ============================================================

NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
NEXT_PUBLIC_WORLDCOIN_APP_ID=
